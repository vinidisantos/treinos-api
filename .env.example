PORT=8080

# URL pública da API usada no OpenAPI (/docs) e no Better Auth.
# Local: http://localhost:8080
# Produção (Render): pode omitir — o Render define RENDER_EXTERNAL_URL automaticamente.
API_BASE_URL=http://localhost:8080

# Opcional em produção no Render (geralmente não precisa definir manualmente).
# RENDER_EXTERNAL_URL=

# URL pública do frontend (ex: https://seudominio.com)
WEB_APP_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/treinos-api

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8080

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GOOGLE_GENERATIVE_AI_API_KEY=
